   4:LQR/LQR.c     **** // 内部函数声明
   5:LQR/LQR.c     **** static float anti_windup(float integral, float max_integral);
   6:LQR/LQR.c     **** static float output_limit(float output, float max_output);
   7:LQR/LQR.c     **** // 初始化LQR速度控制器
   8:LQR/LQR.c     **** void lqr_speed_init(LQR_SpeedController* ctrl, 
   9:LQR/LQR.c     ****                    float k_speed, float k_integral,
  10:LQR/LQR.c     ****                    float max_output, float max_integral) {
  11:LQR/LQR.c     ****     if (ctrl == NULL) return;
  12:LQR/LQR.c     ****     // 初始化参数
  13:LQR/LQR.c     ****     ctrl->k_speed = k_speed;
  14:LQR/LQR.c     ****     ctrl->k_integral = k_integral;
  15:LQR/LQR.c     ****     ctrl->max_output = max_output;
  16:LQR/LQR.c     ****     ctrl->max_integral = max_integral;
  17:LQR/LQR.c     ****     ctrl->integral = 0.0f;
  18:LQR/LQR.c     ****     ctrl->prev_error = 0.0f;
  19:LQR/LQR.c     ****     ctrl->update_time = 0;
  20:LQR/LQR.c     **** }
  21:LQR/LQR.c     **** // 更新LQR速度控制计算(需按固定周期调用)
  22:LQR/LQR.c     **** 
  23:LQR/LQR.c     **** float   lqr_speed_update(LQR_SpeedController* ctrl, 
  24:LQR/LQR.c     ****                       float target_speed, float current_speed,
  25:LQR/LQR.c     ****                       float delta_time) {
  26:LQR/LQR.c     ****     if (ctrl == NULL || delta_time <= 0.0f) {
  27:LQR/LQR.c     ****         return 0.0f;
  28:LQR/LQR.c     ****     }
  29:LQR/LQR.c     ****     
  30:LQR/LQR.c     ****     // 计算速度误差
ARM GAS  C:\Users\lsj\AppData\Local\Temp\ccQ1VZUZ.s 			page 2


  31:LQR/LQR.c     ****     float error = target_speed - current_speed;
  32:LQR/LQR.c     ****     
  33:LQR/LQR.c     ****     // 积分项更新(梯形积分提高精度)
  34:LQR/LQR.c     ****     ctrl->integral += (error + ctrl->prev_error) * delta_time * 0.5f;
  35:LQR/LQR.c     ****     ctrl->prev_error = error;
  36:LQR/LQR.c     ****     
  37:LQR/LQR.c     ****     // 抗积分饱和
  38:LQR/LQR.c     ****     ctrl->integral = anti_windup(ctrl->integral, ctrl->max_integral);
  39:LQR/LQR.c     ****     
  40:LQR/LQR.c     ****     // LQR控制律: u = k_speed * error + k_integral * integral
  41:LQR/LQR.c     ****     float control_output = ctrl->k_speed * error + ctrl->k_integral * ctrl->integral;
  42:LQR/LQR.c     ****     
  43:LQR/LQR.c     ****     // 输出限幅
  44:LQR/LQR.c     ****     return output_limit(control_output, ctrl->max_output);
  45:LQR/LQR.c     **** }
  46:LQR/LQR.c     **** // 自动更新函数(推荐使用)
  47:LQR/LQR.c     **** float lqr_speed_update_auto(LQR_SpeedController* ctrl,
  48:LQR/LQR.c     ****                            float target_speed, float current_speed,
  49:LQR/LQR.c     ****                            uint32_t current_time) {
  50:LQR/LQR.c     ****     if (ctrl == NULL) return 0.0f;
  51:LQR/LQR.c     ****     
  52:LQR/LQR.c     ****     float delta_time = 0.01f; // 默认10ms
  53:LQR/LQR.c     ****     
  54:LQR/LQR.c     ****     if (ctrl->update_time > 0) {
  55:LQR/LQR.c     ****         // 计算实际时间间隔(秒)
  56:LQR/LQR.c     ****         delta_time = (current_time - ctrl->update_time) * 0.001f;
  57:LQR/LQR.c     ****         // 限制时间间隔在合理范围内(1ms ~ 100ms)
  58:LQR/LQR.c     ****         if (delta_time < 0.001f) delta_time = 0.001f;
  59:LQR/LQR.c     ****         if (delta_time > 0.1f) delta_time = 0.1f;
  60:LQR/LQR.c     ****     }
  61:LQR/LQR.c     ****     
  62:LQR/LQR.c     ****     ctrl->update_time = current_time;
  63:LQR/LQR.c     ****     return lqr_speed_update(ctrl, target_speed, current_speed, delta_time);
  64:LQR/LQR.c     **** }
  65:LQR/LQR.c     **** // 重置控制器状态(积分清零)
  66:LQR/LQR.c     **** void lqr_speed_reset(LQR_SpeedController* ctrl) {
  67:LQR/LQR.c     ****     if (ctrl == NULL) return;
  68:LQR/LQR.c     ****     
  69:LQR/LQR.c     ****     ctrl->integral = 0.0f;
  70:LQR/LQR.c     ****     ctrl->prev_error = 0.0f;
  71:LQR/LQR.c     ****     ctrl->update_time = 0;
  72:LQR/LQR.c     **** }
